# ============================================================
# Constitutional Reflective System - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Async PostgreSQL URL for SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://crs:crs@localhost:5432/crs

# Synchronous URL used only by Alembic migrations
DATABASE_SYNC_URL=postgresql+psycopg2://crs:crs@localhost:5432/crs

# ------------------------------------------------------------
# Redis (optional - used for event bus and caching)
# ------------------------------------------------------------
# Leave empty to use in-process event bus
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# LLM Provider Keys
# ------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Default provider to use when not specified
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# ------------------------------------------------------------
# GitHub App Integration
# ------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github_app_private_key.pem
# Or inline PEM (for environments without filesystem secrets):
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
GITHUB_WEBHOOK_SECRET=

# ------------------------------------------------------------
# CRS Server (used by CLI and agents)
# ------------------------------------------------------------
CRS_SERVER_URL=http://localhost:8000
CRS_API_KEY=

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Secret key for signing JWTs and session tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# JWT token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------
# Runtime
# ------------------------------------------------------------
# one of: development, staging, production
ENVIRONMENT=development

# one of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Use JSON structured logging (recommended for production)
LOG_JSON=false

# Number of worker processes (uvicorn)
WORKERS=1

# Server host/port
HOST=0.0.0.0
PORT=8000

# ------------------------------------------------------------
# Sandbox / Evaluation
# ------------------------------------------------------------
# Docker image used for sandboxed candidate evaluation
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_TIMEOUT_SECONDS=300
SANDBOX_MEMORY_MB=512

# ------------------------------------------------------------
# Telemetry (optional)
# ------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=crs-server
