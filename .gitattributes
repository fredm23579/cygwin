# -*- conf -*-

## Set merge driver for ChangeLog files 
# See gnulib's lib/git-merge-changelog.c (or git-merge-changelog(1))
# for per-user setup instructions.
#
# The short version of this (optional) procedure is:
# 
# (1) Install git-merge-changelog (this is the tricky part!)
#
# (2) Add something like the following to your ~/.gitconfig:
#
# [merge "merge-changelog"]
#         name = GNU-style ChangeLog merge driver
#         driver = git-merge-changelog %O %A %B
#
# (3) Enjoy mostly effortless ChangeLog merges, at least until the
#     file gets renamed again ...

ChangeLog       merge=merge-changelog

# ── Line ending normalization ──────────────────────────────────────────────────
# Ensure shell scripts always use LF (Unix line endings), even on Windows.
# PowerShell scripts use CRLF as Windows expects them, but LF also works.
*.sh            text eol=lf
*.bash          text eol=lf
configure       text eol=lf
*.ac            text eol=lf
*.am            text eol=lf

# PowerShell scripts: use CRLF on Windows checkout, LF in repo
*.ps1           text eol=crlf
*.psm1          text eol=crlf
*.psd1          text eol=crlf

# Documentation / markup: LF
*.md            text eol=lf
*.xml           text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.json          text eol=lf

# C / C++ source: LF
*.c             text eol=lf
*.cc            text eol=lf
*.h             text eol=lf
*.in            text eol=lf

# Binary files: no conversion
*.exe           binary
*.dll           binary
*.o             binary
*.a             binary
*.pdf           binary
*.png           binary
*.jpg           binary
*.ico           binary
